# Backend API (no trailing slash). Local dev: point at the Express server.
VITE_API_URL=http://localhost:3001

# Netlify production (repo netlify.toml): VITE_API_URL=/backend so the site calls same-origin /backend/*
# and Netlify proxies to Railway — no CORS. Optional: use a full https API URL instead.

# Optional — not used by current client/src (auth goes through the API). Uncomment if you add a Supabase client in the browser.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional — checkout uses server-side Stripe Checkout; set only if you add Stripe.js or Elements in the client.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
