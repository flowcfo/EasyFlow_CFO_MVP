PORT=3001
NODE_ENV=development

# Supabase (used by server/db/supabase.js)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — used by server/routes/stripe.js (maps PRICE_ID to tier in shared/constants.js)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CLARITY_PRICE_ID=price_xxx
STRIPE_CONTROL_PRICE_ID=price_xxx
STRIPE_HARVEST_PRICE_ID=price_xxx
STRIPE_PARTNER_STARTER_PRICE_ID=price_xxx
STRIPE_PARTNER_GROWTH_PRICE_ID=price_xxx
STRIPE_PARTNER_SCALE_PRICE_ID=price_xxx
# Optional: extra partner seats (server/routes/stripe.js checkout)
STRIPE_SEAT_PRICE_ID=price_xxx

# Anthropic Claude — used by server/ai/* and server/routes/ai.js (interpretScore, chat, action plans, pricing AI, weekly briefs)
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: encrypt persisted AI conversation payloads (server/ai/conversationEncryption.js)
# CONVERSATION_ENCRYPTION_KEY=

# QuickBooks Online (server/integrations/qbo/*)
INTUIT_CLIENT_ID=your-client-id
INTUIT_CLIENT_SECRET=your-client-secret
INTUIT_REDIRECT_URI=http://localhost:3001/integrations/qbo/callback
INTUIT_ENVIRONMENT=sandbox

# Other accounting integrations — set only for providers you enable (see server/integrations/*/auth.js)
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=
# FRESHBOOKS_CLIENT_ID=
# FRESHBOOKS_CLIENT_SECRET=
# FRESHBOOKS_REDIRECT_URI=
# WAVE_CLIENT_ID=
# WAVE_CLIENT_SECRET=
# WAVE_REDIRECT_URI=
# SAGE_CLIENT_ID=
# SAGE_CLIENT_SECRET=
# SAGE_REDIRECT_URI=
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REDIRECT_URI=

# App URLs
# Browser origin(s) allowed by CORS (comma-separated). Include your Netlify URL when the API is on Railway/etc.
# Example: http://localhost:5173,https://your-app.netlify.app
FRONTEND_URL=http://localhost:5173
