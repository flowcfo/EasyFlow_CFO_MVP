# Backend API — required by client/src/utils/api.js (no trailing slash)
VITE_API_URL=http://localhost:3001

# Netlify production: add VITE_API_URL in Site configuration → Environment variables (used at build time), e.g.
# VITE_API_URL=https://your-service.up.railway.app
# Then redeploy. The API must list your Netlify URL in FRONTEND_URL (comma-separated) for CORS.

# Optional — not used by current client/src (auth goes through the API). Uncomment if you add a Supabase client in the browser.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional — checkout uses server-side Stripe Checkout; set only if you add Stripe.js or Elements in the client.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
